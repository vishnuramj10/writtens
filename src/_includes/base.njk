<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != "Writtens" %}{{ title }} — Writtens{% else %}Writtens{% endif %}</title>
  <meta name="description" content="{{ description or 'A space for writing.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <header class="site-header">
    <nav class="nav-container">
      <a href="/" class="site-logo"><span class="logo-w">W</span>rittens</a>
      <ul class="nav-links">
        <li><a href="/">Reading</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </nav>
